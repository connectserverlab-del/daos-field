    { "id": "soul",           "name": "Soul",           "affects": ["spirit", "qi"] },
    { "id": "comprehension",  "name": "Comprehension",  "affects": ["comprehension", "cultivationSpeed"] },
    { "id": "luck",           "name": "Luck",           "affects": ["luck", "tribulation"] },
    { "id": "destiny",        "name": "Destiny",        "affects": ["luck", "global"] }
