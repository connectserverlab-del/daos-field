    { "g": 3, "id": "uncommon", "name": "Uncommon", "weight": 22, "mult": 1.12 },
    { "g": 4, "id": "rare",     "name": "Rare",     "weight": 14, "mult": 1.28 },
    { "g": 5, "id": "epic",     "name": "Epic",     "weight": 6,  "mult": 1.50 },
    { "g": 6, "id": "heavenly", "name": "Heavenly", "weight": 2,  "mult": 1.80 }
